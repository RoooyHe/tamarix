{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "points": {
      "type": "number",
      "minimum": 0,
      "description": "Estimate value"
    },
    "unit": {
      "type": "string",
      "enum": ["story_points", "hours", "days"],
      "description": "Estimate unit"
    }
  },
  "required": ["points", "unit"],
  "additionalProperties": false
}
